@page "/asset-management"
@attribute [Authorize(Policy = "Admin")]
@using Web_JbcHrms.Models
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@inject IJSRuntime JSRuntime
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<PageTitle>Asset Management</PageTitle>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <div>
        <h1 class="h2">Asset Management</h1>
        <p class="text-muted mb-0">Dashboard summary of asset inventory and employee assignments</p>
    </div>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a href="asset-tagging" class="btn btn-sm btn-outline-info me-2 mb-2">
            <i class="bi bi-tags"></i> Asset Tagging
        </a>
        <InputFile id="@AssetImportFileInputId" accept=".csv" style="position: absolute; left: -9999px;" OnChange="HandleAssetImportFileChange" />
        <label for="@AssetImportFileInputId" class="btn btn-sm btn-outline-success me-2 mb-2">
            <i class="bi bi-upload"></i> Bulk Import CSV
        </label>
        <button type="button" class="btn btn-sm btn-outline-primary mb-2" @onclick="OpenAddModal">
            <i class="bi bi-plus-lg"></i> Add New Asset
        </button>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-primary h-100 shadow-sm" role="button" style="cursor: pointer;" @onclick="OpenAssetListFeature">
            <div class="card-body">
                <h5 class="card-title mb-1">Total Assets</h5>
                <p class="display-6 mb-0">@TotalAssets</p>
                <small class="text-muted">All assets in inventory</small>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-success h-100 shadow-sm" role="button" style="cursor: pointer;" @onclick="OpenAvailableAssets">
            <div class="card-body">
                <h5 class="card-title mb-1">In Hand</h5>
                <p class="display-6 mb-0">@AvailableAssets</p>
                <small class="text-muted">Available for assignment</small>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-warning h-100 shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-1">Assigned</h5>
                <p class="display-6 mb-0">@AssignedAssets</p>
                <small class="text-muted">Assets currently assigned</small>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-secondary h-100 shadow-sm" role="button" style="cursor: pointer;" @onclick="OpenEmployeeDirectory">
            <div class="card-body">
                <h5 class="card-title mb-1">Employees</h5>
                <p class="display-6 mb-0">@TotalEmployees</p>
                <small class="text-muted">Employees in directory</small>
            </div>
        </div>
    </div>
</div>

<div class="d-flex flex-wrap gap-2 align-items-center mb-4">
    <!-- <button class="btn btn-outline-primary" @onclick="OpenAssetListFeature" disabled="@(assets == null || !assets.Any())">
        <i class="bi bi-list-ul"></i> View Asset List
    </button> -->
    <button class="btn btn-outline-secondary" @onclick="OpenIndividualAssetsFeature" disabled="@(employees == null || !employees.Any())">
        <i class="bi bi-person-lines-fill"></i> View Individual Assets
    </button>
    <button class="btn btn-outline-primary" @onclick="OpenTeamAssetsFeature" disabled="@(assets == null || !assets.Any(a => !string.IsNullOrWhiteSpace(a.AssignedTeamName)))">
        <i class="bi bi-people"></i> View Team Assets
    </button>
    <button class="btn btn-outline-info" @onclick="OpenEmployeeProductHistoryFeature" disabled="@(employees == null || !employees.Any())">
        <i class="bi bi-clock-history"></i> Employee Product History
    </button>
    <button class="btn btn-outline-danger" @onclick="OpenTrashFeature" disabled="@(!GetDeletedAssets().Any())">
        <i class="bi bi-trash3"></i> Trash
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(assetImportMessage))
{
    <div class="alert @(assetImportSuccess ? "alert-success" : "alert-danger")">@assetImportMessage</div>
}

@if (isAssetListFeatureOpen)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="h5">Asset List</h2>
            <p class="text-muted mb-0">Browse all assets and preview/print the full inventory.</p>
        </div>
        <div class="btn-group">
            <button class="btn btn-outline-secondary" @onclick="BackToDashboard">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </button>
            <button class="btn btn-outline-primary" @onclick="PreviewAllAssetList" disabled="@(assets == null || !assets.Any())">
                <i class="bi bi-printer"></i> Preview / Print
            </button>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-striped table-hover mt-3 align-middle" id="assetTable">
                    <thead class="table-light">
                        <tr>
                            <th>Asset Tag</th>
                            <th>Type</th>
                            <th>Model</th>
                            <th>Config</th>
                            <th>Serial Number</th>
                            <th>Purchase Date</th>
                            <th>Status</th>
                            <th>Assigned To</th>
                            <th>Notes</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (GetVisibleAssets().Any())
                        {
                            foreach (var asset in GetVisibleAssets())
                            {
                                <tr>
                                    <td><strong>@asset.AssetTag</strong></td>
                                    <td>@asset.Type</td>
                                    <td>@asset.Model</td>
                                    <td>@asset.Config</td>
                                    <td>@asset.SerialNumber</td>
                                    <td>@(asset.PurchaseDate?.ToString("dd MMM yyyy") ?? "N/A")</td>
                                    <td><span class="badge @(asset.Status == "Available" ? "bg-success" : "bg-secondary")">@asset.Status</span></td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(asset.AssignedTeamName))
                                        {
                                            <span>Team: @asset.AssignedTeamName</span>
                                            @if (!string.IsNullOrWhiteSpace(asset.ResponsiblePerson))
                                            {
                                                <div class="small text-muted">Responsible: @asset.ResponsiblePerson</div>
                                            }
                                        }
                                        else if (asset.AssignedEmployeeID.HasValue)
                                        {
                                            var emp = employees?.FirstOrDefault(e => e.EmployeeID == asset.AssignedEmployeeID.Value);
                                            if (emp != null)
                                            {
                                                <span>@emp.EmployeeCode - @emp.EmployeeName</span>
                                            }
                                            else
                                            {
                                                <span>Emp ID: @asset.AssignedEmployeeID.Value</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">Unassigned</span>
                                        }
                                    </td>
                                    <td>@asset.Notes</td>
                                    <td class="text-nowrap">
                                        <button class="btn btn-sm btn-outline-secondary me-1" title="Edit" @onclick="() => OpenEditModal(asset)">
                                            <i class="bi bi-pencil"></i> Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger me-1" title="Delete" @onclick="() => OpenDeleteModal(asset)">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                        <button class="btn btn-sm btn-outline-info" title="History" @onclick="() => ShowHistory(asset)">
                                            <i class="bi bi-clock-history"></i> History
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="10" class="text-center py-4 text-muted">No assets found. Click "Add New Asset" to create one.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else if (isAvailableAssetsFeatureOpen)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="h5">In Hand Assets</h2>
            <p class="text-muted mb-0">Browse all assets currently available for assignment.</p>
        </div>
        <button class="btn btn-outline-secondary" @onclick="BackToDashboard">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </button>
    </div>
    <div class="table-responsive">
        <table class="table table-striped table-hover mt-3 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Asset Tag</th>
                    <th>Type</th>
                    <th>Model</th>
                    <th>Config</th>
                    <th>Serial Number</th>
                    <th>Purchase Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var asset in GetAvailableAssets())
                {
                    <tr>
                        <td><strong>@asset.AssetTag</strong></td>
                        <td>@asset.Type</td>
                        <td>@asset.Model</td>
                        <td>@asset.Config</td>
                        <td>@asset.SerialNumber</td>
                        <td>@(asset.PurchaseDate?.ToString("dd MMM yyyy") ?? "N/A")</td>
                        <td class="text-nowrap">
                            <button class="btn btn-sm btn-outline-secondary me-1" title="Edit" @onclick="() => OpenEditModal(asset)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger me-1" title="Delete" @onclick="() => OpenDeleteModal(asset)">
                                <i class="bi bi-trash"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenAssignModal(asset)">
                                <i class="bi bi-person-plus"></i> Assign
                            </button>
                        </td>
                    </tr>
                }
                @if (!GetAvailableAssets().Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">No assets are currently in hand.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (isIndividualAssetsFeatureOpen)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="h5">Individual Assets</h2>
            <p class="text-muted mb-0">Select an employee to preview and print assigned assets.</p>
        </div>
        <button class="btn btn-outline-secondary" @onclick="BackToDashboard">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </button>
    </div>
    <div class="row mb-3">
        <div class="col-md-6 col-lg-4">
            <label class="form-label">Select Employee</label>
            <select class="form-select" @bind="selectedEmployeeForAssetList" @bind:after="UpdateSelectedEmployeeAssets">
                <option value="">-- Select Employee --</option>
                @foreach (var employee in employees ?? Enumerable.Empty<EmployeeDirectoryEntry>())
                {
                    <option value="@employee.EmployeeID">@employee.EmployeeCode - @employee.EmployeeName</option>
                }
            </select>
        </div>
        <div class="col-md-6 col-lg-4 d-flex align-items-end gap-2">
            <button class="btn btn-outline-primary" @onclick="PreviewIndividualAssetList" disabled="@(selectedEmployeeForAssetList == null)">
                <i class="bi bi-printer"></i> Preview / Print
            </button>
        </div>
    </div>
    @if (selectedEmployeeForAssetList.HasValue && printAssetList.Any())
    {
        <div class="alert alert-info">
            Showing assets assigned to <strong>@SelectedEmployee?.EmployeeCode - @SelectedEmployee?.EmployeeName</strong> (@printAssetList.Count items).
        </div>
        <div class="table-responsive mb-4">
            <table class="table table-bordered table-sm">
                <thead class="table-light">
                    <tr>
                        <th>Asset Tag</th>
                        <th>Type</th>
                        <th>Model</th>
                        <th>Config</th>
                        <th>Serial Number</th>
                        <th>Purchase Date</th>
                        <th>Status</th>
                        <th>Notes</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var asset in printAssetList)
                    {
                        <tr>
                            <td><strong>@asset.AssetTag</strong></td>
                            <td>@asset.Type</td>
                            <td>@asset.Model</td>
                            <td>@asset.Config</td>
                            <td>@asset.SerialNumber</td>
                            <td>@(asset.PurchaseDate?.ToString("dd MMM yyyy") ?? "N/A")</td>
                            <td>@asset.Status</td>
                            <td>@asset.Notes</td>
                            <td class="text-nowrap">
                                <button class="btn btn-sm btn-outline-secondary me-1" title="Edit" @onclick="() => OpenEditModal(asset)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" title="Delete" @onclick="() => OpenDeleteModal(asset)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (selectedEmployeeForAssetList.HasValue)
    {
        <div class="alert alert-warning">No assets assigned to the selected employee.</div>
    }
}
else if (isTeamAssetsFeatureOpen)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="h5">Team Assets</h2>
            <p class="text-muted mb-0">Browse assets assigned to teams and view the responsible person.</p>
        </div>
        <button class="btn btn-outline-secondary" @onclick="BackToDashboard">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </button>
    </div>
    <div class="row mb-3">
        <div class="col-md-6 col-lg-4">
            <label class="form-label">Filter by Team</label>
            <select class="form-select" @bind="selectedTeamForAssetList">
                <option value="">-- All Teams --</option>
                @foreach (var teamName in TeamNames)
                {
                    <option value="@teamName">@teamName</option>
                }
            </select>
        </div>
    </div>
    <div class="alert alert-info">
        Showing @GetTeamAssets().Count() team-assigned asset(s).
    </div>
    <div class="table-responsive mb-4">
        <table class="table table-bordered table-sm">
            <thead class="table-light">
                <tr>
                    <th>Asset Tag</th>
                    <th>Type</th>
                    <th>Model</th>
                    <th>Config</th>
                    <th>Serial Number</th>
                    <th>Purchase Date</th>
                    <th>Team</th>
                    <th>Responsible</th>
                    <th>Status</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var asset in GetTeamAssets())
                {
                    <tr>
                        <td><strong>@asset.AssetTag</strong></td>
                        <td>@asset.Type</td>
                        <td>@asset.Model</td>
                        <td>@asset.Config</td>
                        <td>@asset.SerialNumber</td>
                        <td>@(asset.PurchaseDate?.ToString("dd MMM yyyy") ?? "N/A")</td>
                        <td>@asset.AssignedTeamName</td>
                        <td>@asset.ResponsiblePerson</td>
                        <td>@asset.Status</td>
                        <td>@asset.Notes</td>
                        <td class="text-nowrap">
                            <button class="btn btn-sm btn-outline-secondary me-1" title="Edit" @onclick="() => OpenEditModal(asset)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger me-1" title="Delete" @onclick="() => OpenDeleteModal(asset)">
                                <i class="bi bi-trash"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-primary" title="Reassign" @onclick="() => OpenAssignModal(asset)">
                                <i class="bi bi-person-plus"></i> Reassign
                            </button>
                        </td>
                    </tr>
                }
                @if (!GetTeamAssets().Any())
                {
                    <tr>
                        <td colspan="11" class="text-center py-4 text-muted">No team-assigned assets found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (isEmployeeHistoryFeatureOpen)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="h5">Employee Product History</h2>
            <p class="text-muted mb-0">Select an employee to see their assigned product history and asset details.</p>
        </div>
        <button class="btn btn-outline-secondary" @onclick="BackToDashboard">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </button>
    </div>
    <div class="row mb-3">
        <div class="col-md-6 col-lg-4">
            <label class="form-label">Select Employee</label>
            <select class="form-select" @bind="selectedEmployeeForProductHistory" @bind:after="UpdateSelectedEmployeeProductHistory">
                <option value="">-- Select Employee --</option>
                @foreach (var employee in employees ?? Enumerable.Empty<EmployeeDirectoryEntry>())
                {
                    <option value="@employee.EmployeeID">@employee.EmployeeCode - @employee.EmployeeName</option>
                }
            </select>
        </div>
    </div>
    @if (selectedEmployeeForProductHistory.HasValue && SelectedProductHistoryEmployee != null)
    {
        @if (productHistoryAssets.Any())
        {
            <div class="alert alert-info">
                Showing @productHistoryAssets.Count products assigned to <strong>@SelectedProductHistoryEmployee.EmployeeCode - @SelectedProductHistoryEmployee.EmployeeName</strong>.
            </div>
            <div class="table-responsive mb-4">
                <table class="table table-bordered table-sm">
                    <thead class="table-light">
                        <tr>
                            <th>Asset Tag</th>
                            <th>Type</th>
                            <th>Model</th>
                            <th>Config</th>
                            <th>Serial Number</th>
                            <th>Purchase Date</th>
                            <th>Status</th>
                            <th>History Entries</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var asset in productHistoryAssets)
                        {
                            <tr>
                                <td><strong>@asset.AssetTag</strong></td>
                                <td>@asset.Type</td>
                                <td>@asset.Model</td>
                                <td>@asset.Config</td>
                                <td>@asset.SerialNumber</td>
                                <td>@(asset.PurchaseDate?.ToString("dd MMM yyyy") ?? "N/A")</td>
                                <td>@asset.Status</td>
                                <td>@(asset.History?.Count ?? 0)</td>
                                <td class="text-nowrap">
                                    <button class="btn btn-sm btn-outline-info" @onclick="() => ShowHistory(asset)">
                                        <i class="bi bi-clock-history"></i> View History
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-warning">No assigned products found for this employee.</div>
        }
    }
}
else if (isTrashFeatureOpen)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="h5">Trash</h2>
            <p class="text-muted mb-0">Soft deleted assets are shown here. Restore is enabled.</p>
        </div>
        <button class="btn btn-outline-secondary" @onclick="BackToDashboard">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </button>
    </div>
    <div class="table-responsive mb-4">
        <table class="table table-bordered table-sm">
            <thead class="table-light">
                <tr>
                    <th>Asset Tag</th>
                    <th>Type</th>
                    <th>Model</th>
                    <th>Config</th>
                    <th>Serial Number</th>
                    <th>Purchase Date</th>
                    <th>Status</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (GetDeletedAssets().Any())
                {
                    @foreach (var asset in GetDeletedAssets())
                    {
                        <tr>
                            <td><strong>@asset.AssetTag</strong></td>
                            <td>@asset.Type</td>
                            <td>@asset.Model</td>
                            <td>@asset.Config</td>
                            <td>@asset.SerialNumber</td>
                            <td>@(asset.PurchaseDate?.ToString("dd MMM yyyy") ?? "N/A")</td>
                            <td>@asset.Status</td>
                            <td>@asset.Notes</td>
                            <td class="text-nowrap">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => RestoreAsset(asset)">
                                    <i class="bi bi-arrow-counterclockwise"></i> Restore
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center py-4 text-muted">No items in trash.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Add/Edit Asset Modal -->
<div class="modal fade" id="addAssetModal" tabindex="-1" aria-labelledby="addAssetModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addAssetModalLabel">@(isEditing ? "Edit Asset" : "Add New Asset")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" @onclick="CloseAddModal"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="mb-3">
                        <label class="form-label">Asset Type</label>
                        <select class="form-select" @bind="newAssetType" @bind:after="GenerateAssetTag" disabled="@isEditing">
                            <option value="">-- Select Type --</option>
                            @foreach (var assetType in assetTypeOptions)
                            {
                                <option value="@assetType">@assetType</option>
                            }
                        </select>
                    </div>

                    @if (newAssetType == "Other")
                    {
                        <div class="mb-3">
                            <label class="form-label">Custom Asset Type</label>
                            <input type="text" class="form-control" @bind="customAssetType" @bind:event="oninput" @bind:after="GenerateAssetTag" placeholder="e.g. SSD Enclosure" disabled="@isEditing" />
                        </div>
                    }
                    
                    <div class="mb-3">
                        <label class="form-label">Asset Tag (Auto-generated)</label>
                        <input type="text" class="form-control bg-light" value="@newAssetTag" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Brand</label>
                        <select class="form-select" @bind="newBrand">
                            <option value="">-- Select Brand --</option>
                            @foreach (var brand in GetBrandOptions())
                            {
                                <option value="@brand">@brand</option>
                            }
                        </select>
                    </div>

                    @if (newBrand == "Other")
                    {
                        <div class="mb-3">
                            <label class="form-label">Custom Brand</label>
                            <input type="text" class="form-control" @bind="customBrand" placeholder="e.g. No Brand" />
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Model</label>
                        <input type="text" class="form-control" @bind="newModel" placeholder="e.g. M1 2020" />
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">RAM</label>
                            <select class="form-select" @bind="newRam">
                                <option value="">-- Select RAM --</option>
                                @foreach (var ram in ramOptions)
                                {
                                    <option value="@ram">@ram</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">SSD</label>
                            <select class="form-select" @bind="newSsd">
                                <option value="">-- Select SSD --</option>
                                @foreach (var ssd in ssdOptions)
                                {
                                    <option value="@ssd">@ssd</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Additional Config (Optional)</label>
                        <input type="text" class="form-control" @bind="newAdditionalConfig" placeholder="e.g. Type-C Hub, Intel i7" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Serial Number</label>
                        <input type="text" class="form-control" @bind="newSerialNumber" placeholder="e.g. C02X..." />
                    </div>

                    <div class="mb-3">
