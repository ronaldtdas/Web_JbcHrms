    private async Task ImportSelectedAssets()
    {
        if (importPreviewData == null)
        {
            return;
        }

        var selectedAssets = importPreviewData.Where(p => p.IsSelected).ToList();
        if (!selectedAssets.Any())
        {
            assetImportSuccess = false;
            assetImportMessage = "No assets selected for import.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var importedCount = 0;
        var errorMessages = new List<string>();

        foreach (var preview in selectedAssets)
        {
            var asset = preview.Asset;
            try
            {
                var request = new HttpRequestMessage(HttpMethod.Put, $"{FirebaseDatabaseURL}/assets/{asset.AssetTag}.json?auth={FirebaseApiKey}");
                request.Content = JsonContent.Create(asset);

                var response = await Http.SendAsync(request);
                if (!response.IsSuccessStatusCode)
                {
                    errorMessages.Add($"{asset.AssetTag}: {(int)response.StatusCode} {response.ReasonPhrase}");
                    continue;
                }

                assets.Add(asset);
                importedCount++;
            }
            catch (Exception ex)
            {
                errorMessages.Add($"{asset.AssetTag}: {ex.Message}");
            }
        }

        dataTableInitialized = false;
        assetImportSuccess = importedCount > 0;
        assetImportMessage = importedCount == 0
            ? $"No assets were imported."
            : $"Successfully imported {importedCount} asset{(importedCount > 1 ? "s" : "")} from {importPreviewFileName}";

        if (errorMessages.Any())
        {
            assetImportMessage += $" ({string.Join("; ", errorMessages.Take(3))})";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveAsset()
    {
        var effectiveType = GetEffectiveAssetType();
        if (string.IsNullOrWhiteSpace(effectiveType)) return;

        if (!isEditing && string.IsNullOrEmpty(newAssetTag))
        {
            GenerateAssetTag();
        }

        var asset = isEditing 
            ? assets.FirstOrDefault(a => a.AssetTag == newAssetTag) 
            : new Asset { AssetTag = newAssetTag, Type = effectiveType };

        if (asset == null) return;

        // Keep track of changes for History
        string historyAction = "";
        var effectiveTeamName = string.IsNullOrWhiteSpace(newAssignedTeamName) ? null : newAssignedTeamName.Trim();
        var effectiveResponsible = string.IsNullOrWhiteSpace(newResponsiblePerson) ? null : newResponsiblePerson.Trim();
        int? newAssignee = newStatus == "Assigned" && newAssignmentType == "Individual" ? newAssignedEmployeeID : null;
        bool isTeamAssignment = newStatus == "Assigned" && newAssignmentType == "Team";
        string? newAssignmentDisplay = isTeamAssignment
            ? (effectiveTeamName is not null ? $"Team {effectiveTeamName}{(effectiveResponsible is not null ? $" (Responsible: {effectiveResponsible})" : string.Empty)}" : null)
            : (newAssignee.HasValue ? GetEmployeeName(newAssignee.Value) : null);

        string GetEmployeeName(int id)
        {
            var emp = employees?.FirstOrDefault(e => e.EmployeeID == id);
            return emp != null ? $"{emp.EmployeeCode} - {emp.EmployeeName}" : $"Emp ID: {id}";
        }

        string? previousAssignmentDisplay = asset.AssignedEmployeeID.HasValue
            ? GetEmployeeName(asset.AssignedEmployeeID.Value)
            : !string.IsNullOrWhiteSpace(asset.AssignedTeamName)
                ? $"Team {asset.AssignedTeamName}{(string.IsNullOrWhiteSpace(asset.ResponsiblePerson) ? string.Empty : $" (Responsible: {asset.ResponsiblePerson})")}"
                : null;

        if (!isEditing)
        {
            if (!string.IsNullOrWhiteSpace(newAssignmentDisplay))
            {
                historyAction = $"Assigned to {newAssignmentDisplay}";
            }
        }
        else if (!string.Equals(previousAssignmentDisplay, newAssignmentDisplay, StringComparison.OrdinalIgnoreCase))
        {
            if (!string.IsNullOrWhiteSpace(newAssignmentDisplay))
            {
                historyAction = $"Assigned to {newAssignmentDisplay}";
            }
            else if (!string.IsNullOrWhiteSpace(previousAssignmentDisplay))
            {
                historyAction = $"Unassigned from {previousAssignmentDisplay}";
            }
        }

        // Add history entry if there was a meaningful update or creation
        if (!string.IsNullOrEmpty(historyAction))
        {
            if (asset.History == null) asset.History = new List<AssetHistory>();
            asset.History.Add(new AssetHistory
            {
                Action = historyAction,
                Notes = newNotes
            });
        }

        asset.Type = effectiveType;
        asset.SerialNumber = newSerialNumber;
        asset.Model = BuildModelValue();
        asset.Config = BuildConfigValue();
        asset.PurchaseDate = newPurchaseDate;
        asset.Status = newStatus;
        asset.Notes = newNotes;
        asset.AssignedEmployeeID = newAssignee;
        asset.AssignedTeamName = isTeamAssignment ? effectiveTeamName : null;
        asset.ResponsiblePerson = isTeamAssignment ? effectiveResponsible : null;

        try
        {
            var request = new HttpRequestMessage(HttpMethod.Put, $"{FirebaseDatabaseURL}/assets/{asset.AssetTag}.json?auth={FirebaseApiKey}");
            request.Content = JsonContent.Create(asset);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                if (!isEditing)
                {
                    assets.Add(asset);
                }

                dataTableInitialized = false;
                
                // Refresh DataTable
                await JSRuntime.InvokeVoidAsync("hideModal", "addAssetModal");
                ResetForm();
            }
            else
            {
                Console.WriteLine($"Error saving asset: {response.ReasonPhrase}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception saving asset: {ex.Message}");
        }
    }



    private string GenerateNextAssetTag(string effectiveType)
    {
        string typePrefix = effectiveType.Replace(" ", "");
        var effectiveTypeKey = GetTypeKey(effectiveType);
        int count = assets.Count(a => GetTypeKey(a.Type) == effectiveTypeKey);

        return $"JBC-{typePrefix}-{(count + 1):D2}";
    }

    private static string GetCsvField(IReadOnlyList<string> fields, int index)
    {
        return index >= 0 && index < fields.Count ? fields[index].Trim() : string.Empty;
    }

    private static List<string> ParseCsvLine(string line)
    {
        var fields = new List<string>();
        var current = new System.Text.StringBuilder();
        var inQuotes = false;

        for (var i = 0; i < line.Length; i++)
        {
            var character = line[i];

            if (character == '"')
            {
                if (inQuotes && i + 1 < line.Length && line[i + 1] == '"')
                {
                    current.Append('"');
                    i++;
                }
                else
                {
                    inQuotes = !inQuotes;
                }

                continue;
            }

            if (character == ',' && !inQuotes)
            {
                fields.Add(current.ToString().Trim());
                current.Clear();
                continue;
            }

            current.Append(character);
        }

        fields.Add(current.ToString().Trim());
        return fields;
    }

    private static string? NormalizeImportedCell(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var trimmed = value.Trim();
        if (trimmed.Equals("n/a", StringComparison.OrdinalIgnoreCase) ||
            trimmed.Equals("na", StringComparison.OrdinalIgnoreCase) ||
            trimmed == "-" ||
            trimmed == "---" ||
            trimmed.Equals("none", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        return trimmed;
    }

    private int? ResolveEmployeeId(string? employeeCode, string? assignedPerson)
    {
        var parsedEmployeeId = ParseEmployeeId(employeeCode);
        if (parsedEmployeeId.HasValue)
        {
            var exactEmployee = employees.FirstOrDefault(employee => employee.EmployeeID == parsedEmployeeId.Value);
            if (exactEmployee != null)
            {
                return exactEmployee.EmployeeID;
            }
        }

        var normalizedName = NormalizeComparableText(assignedPerson);
        if (!string.IsNullOrWhiteSpace(normalizedName))
        {
            var matchedByName = employees.FirstOrDefault(employee => NormalizeComparableText(employee.EmployeeName) == normalizedName);
            if (matchedByName != null)
            {
                return matchedByName.EmployeeID;
            }
        }

        return null;
    }

    private static int? ParseEmployeeId(string? employeeCode)
    {
        if (string.IsNullOrWhiteSpace(employeeCode))
        {
            return null;
        }

        var digits = new string(employeeCode.Where(char.IsDigit).ToArray());
        return int.TryParse(digits, out var parsedEmployeeId) ? parsedEmployeeId : null;
    }

    private static string NormalizeComparableText(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return new string(value.Where(char.IsLetterOrDigit).ToArray()).ToLowerInvariant();
    }

    private string BuildModelValue(string? brand, string? model)
    {
        var normalizedBrand = NormalizeImportedCell(brand);
        var normalizedModel = NormalizeImportedCell(model);

        if (string.IsNullOrWhiteSpace(normalizedBrand))
        {
            return normalizedModel ?? string.Empty;
        }

        if (string.IsNullOrWhiteSpace(normalizedModel))
        {
            return normalizedBrand;
        }

        return $"{normalizedBrand} {normalizedModel}";
    }

    private string BuildConfigValue(string? ram, string? ssd, string? additionalConfig)
    {
        var parts = new List<string>();

        var normalizedRam = NormalizeImportedCell(ram);
        if (!string.IsNullOrWhiteSpace(normalizedRam))
        {
            parts.Add($"RAM: {normalizedRam}");
        }

        var normalizedSsd = NormalizeImportedCell(ssd);
        if (!string.IsNullOrWhiteSpace(normalizedSsd))
        {
            parts.Add($"SSD: {normalizedSsd}");
        }

        var normalizedAdditionalConfig = NormalizeImportedCell(additionalConfig);
        if (!string.IsNullOrWhiteSpace(normalizedAdditionalConfig))
        {
            parts.Add(normalizedAdditionalConfig);
        }

        return string.Join(" | ", parts);
    }

