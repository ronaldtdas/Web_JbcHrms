    private void OpenEmployeeProductHistoryFeature()
    {
        isEmployeeHistoryFeatureOpen = true;
        isAssetListFeatureOpen = false;
        isIndividualAssetsFeatureOpen = false;
        isTeamAssetsFeatureOpen = false;
        isAvailableAssetsFeatureOpen = false;
        selectedEmployeeForProductHistory = null;
        productHistoryAssets.Clear();
    }

    private void OpenEmployeeDirectory()
    {
        NavigationManager.NavigateTo("/employees");
    }

    private void BackToDashboard()
    {
        isAssetListFeatureOpen = false;
        isIndividualAssetsFeatureOpen = false;
        isTeamAssetsFeatureOpen = false;
        isEmployeeHistoryFeatureOpen = false;
        isAvailableAssetsFeatureOpen = false;
        isTrashFeatureOpen = false;
        selectedEmployeeForAssetList = null;
        selectedTeamForAssetList = string.Empty;
        selectedEmployeeForProductHistory = null;
        selectedAssetToAssign = null;
        selectedAssetToDelete = null;
        selectedAssignmentEmployeeID = null;
        selectedAssignmentNotes = string.Empty;
        printAssetList.Clear();
        productHistoryAssets.Clear();
    }

    private void OpenTrashFeature()
    {
        isTrashFeatureOpen = true;
        isAssetListFeatureOpen = false;
        isIndividualAssetsFeatureOpen = false;
        isTeamAssetsFeatureOpen = false;
        isEmployeeHistoryFeatureOpen = false;
        isAvailableAssetsFeatureOpen = false;
        selectedAssetToAssign = null;
        selectedAssetToDelete = null;
