    private static bool ShouldShowConfig(Asset asset)
    {
        return asset.Type != null && (
            string.Equals(asset.Type, "Laptop", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(asset.Type, "Desktop", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(asset.Type, "Macbook", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(asset.Type, "Macmini", StringComparison.OrdinalIgnoreCase));
    }

    private static bool ShouldShowModelAndSerial(Asset asset)
    {
        return !string.Equals(asset.Type, "Laptop Stand", StringComparison.OrdinalIgnoreCase);
    }

    private void ParseConfigForEdit(string? config)
    {
        newRam = "";
        newSsd = "";
        newAdditionalConfig = "";

        if (string.IsNullOrWhiteSpace(config))
        {
            return;
        }

        var parts = config.Split('|', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        var remaining = new List<string>();

        foreach (var part in parts)
        {
            if (part.StartsWith("RAM:", StringComparison.OrdinalIgnoreCase))
            {
                newRam = part.Substring(4).Trim();
                continue;
            }

            if (part.StartsWith("SSD:", StringComparison.OrdinalIgnoreCase))
            {
                newSsd = part.Substring(4).Trim();
                continue;
            }

            remaining.Add(part);
        }

        if (remaining.Any())
        {
            newAdditionalConfig = string.Join(" | ", remaining);
        }
        else if (string.IsNullOrWhiteSpace(newRam) && string.IsNullOrWhiteSpace(newSsd))
        {
            newAdditionalConfig = config;
        }
    }

    private string MapTypeToOption(string? assetType)
    {
        return GetTypeKey(assetType) switch
        {
            "macbook" => "Macbook",
            "macmini" => "Macmini",
            "monitor" => "Monitor",
            "laptop" => "Laptop",
            "desktop" => "Desktop",
            "keyboard" => "Keyboard",
            "mouse" => "Mouse",
            "dongle" => "Dongle",
            "mobile" => "Mobile",
            "usbcable" => "USB Cable",
            "usbhub" => "USB Hub",
            "webcam" => "Webcam",
            "ssd" => "SSD",
            "ups" => "UPS",
            "laptopstand" => "Laptop Stand",
            "accessories" => "Accessories",
            _ => assetType?.Trim() ?? ""
        };
    }

    private string GetTypeKey(string? assetType)
    {
        if (string.IsNullOrWhiteSpace(assetType))
        {
            return string.Empty;
        }

        var cleaned = assetType.Trim().ToLowerInvariant().Replace("-", " ");
        cleaned = string.Join(" ", cleaned.Split(' ', StringSplitOptions.RemoveEmptyEntries));

        return cleaned switch
        {
            "mac book" => "macbook",
            "mac mini" => "macmini",
            "monior" => "monitor",
            "usb cable" => "usbcable",
            "usb hub" => "usbhub",
            "laptop stand" => "laptopstand",
            _ => cleaned.Replace(" ", "")
        };
    }

