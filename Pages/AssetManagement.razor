    private int TeamAssetsCount => assets.Count(a => !a.IsDeleted && !string.IsNullOrWhiteSpace(a.AssignedTeamName));
    private int AvailableAssets => assets.Count(a => a.Status == "Available");
    private int TotalEmployees => employees.Count;
