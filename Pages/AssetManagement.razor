    private List<string> GetBrandOptions()
    {
        var effectiveType = GetEffectiveAssetType();
        if (string.IsNullOrWhiteSpace(effectiveType))
        {
            return new List<string> { "Other" };
        }

        var brandTypeKey = MapTypeToOption(effectiveType);

        if (brandOptionsByType.TryGetValue(brandTypeKey, out var brands))
        {
            return brands;
        }

        return new List<string> { "Other" };
    }

    private string BuildModelValue()
    {
        var brand = newBrand == "Other" ? customBrand.Trim() : newBrand.Trim();
        return BuildModelValue(brand, newModel);
    }

    private string BuildConfigValue()
    {
        return BuildConfigValue(newRam, newSsd, newAdditionalConfig);
    }

    private IEnumerable<Asset> GetOrderedPrintAssetList()
    {
        return printAssetList
            .OrderBy(a => GetPrintPreviewSortRank(a))
            .ThenBy(a => a.AssetTag, StringComparer.OrdinalIgnoreCase);
    }

    private static int GetPrintPreviewSortRank(Asset asset)
    {
        var typeKey = asset.Type == null ? string.Empty : asset.Type.Trim().ToLowerInvariant();
        if (typeKey.Contains("phone") || typeKey.Contains("mobile"))
        {
            return 0;
        }

        if (typeKey == "laptop" || typeKey == "desktop" || typeKey == "macbook" || typeKey == "macmini")
        {
            return 1;
        }

        if (typeKey.Contains("monitor"))
        {
            return 2;
        }

        if (typeKey.Contains("ssd") || typeKey.Contains("hdd") || typeKey.Contains("storage"))
        {
            return 3;
        }

        if (typeKey.Contains("webcam"))
        {
            return 4;
        }

        if (typeKey.Contains("accessories"))
        {
            return 5;
        }

        if (typeKey.Contains("mouse") || typeKey.Contains("keyboard"))
        {
            return 6;
        }

        if (typeKey.Contains("laptopstand") || typeKey.Contains("laptop stand"))
        {
            return 8;
        }

        return 7;
    }

