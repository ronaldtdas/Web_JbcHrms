    private async Task HandleAssetImportFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null)
        {
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(20 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            var content = await reader.ReadToEndAsync();
            await ParseAndPreviewAssets(content, file.Name);
        }
        catch (Exception ex)
        {
            assetImportSuccess = false;
            assetImportMessage = $"Unable to read CSV: {ex.Message}";
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ParseAndPreviewAssets(string content, string fileName)
    {
        var lines = content.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (lines.Length <= 1)
        {
            assetImportSuccess = false;
            assetImportMessage = "CSV file is empty or missing data rows.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        importPreviewData = new List<ImportAssetPreview>();
        var typeIndex = 0;

        for (var lineIndex = 1; lineIndex < lines.Length; lineIndex++)
        {
            var line = lines[lineIndex];
            if (string.IsNullOrWhiteSpace(line))
            {
                continue;
            }

            var fields = ParseCsvLine(line);
            if (fields.Count < 4)
            {
                continue;
            }

            var assignedPerson = GetCsvField(fields, 1);
            var employeeCode = GetCsvField(fields, 2);
            var rawType = GetCsvField(fields, 3);
            var brand = GetCsvField(fields, 4);
            var model = GetCsvField(fields, 5);
            var ram = GetCsvField(fields, 6);
            var ssd = GetCsvField(fields, 7);
            var serialNumber = GetCsvField(fields, 8);

            var effectiveType = MapTypeToOption(rawType);
            if (string.IsNullOrWhiteSpace(effectiveType))
            {
                continue;
            }

            var assetTag = GenerateNextAssetTagWithIndex(effectiveType, typeIndex++);
            var resolvedEmployeeId = ResolveEmployeeId(employeeCode, assignedPerson);
            var assignedEmployeeName = resolvedEmployeeId.HasValue
                ? employees.FirstOrDefault(e => e.EmployeeID == resolvedEmployeeId.Value)?.EmployeeName ?? "Unknown"
                : null;

            var asset = new Asset
            {
                AssetTag = assetTag,
                Type = effectiveType,
                SerialNumber = NormalizeImportedCell(serialNumber),
                PurchaseDate = null,
                Status = resolvedEmployeeId.HasValue ? "Assigned" : "Available",
                Notes = string.Empty,
                AssignedEmployeeID = resolvedEmployeeId,
                Model = BuildModelValue(brand, model),
                Config = BuildConfigValue(ram, ssd, null)
            };

            var isDuplicate = DetectDuplicate(asset);
            var preview = new ImportAssetPreview
            {
                Asset = asset,
                AssignedEmployeeName = assignedEmployeeName,
                IsDuplicate = isDuplicate,
                ValidationWarning = string.IsNullOrWhiteSpace(asset.SerialNumber) ? "No serial" : null,
                IsSelected = !isDuplicate
            };

            importPreviewData.Add(preview);
        }

        importPreviewFileName = fileName;
        await JSRuntime.InvokeVoidAsync("showModal", "importPreviewModal");
        await InvokeAsync(StateHasChanged);
    }

    private string GenerateNextAssetTagWithIndex(string effectiveType, int typeIndex)
    {
        string typePrefix = effectiveType.Replace(" ", "");
        var effectiveTypeKey = GetTypeKey(effectiveType);
        var count = assets.Count(a => GetTypeKey(a.Type) == effectiveTypeKey) + typeIndex;

        return $"JBC-{typePrefix}-{(count + 1):D2}";
    }

    private bool DetectDuplicate(Asset candidate)
    {
        if (string.IsNullOrWhiteSpace(candidate.SerialNumber))
        {
            return false;
        }

        return assets.Any(a => !string.IsNullOrWhiteSpace(a.SerialNumber) && a.SerialNumber.Equals(candidate.SerialNumber, StringComparison.OrdinalIgnoreCase))
            || importPreviewData?.Any(p => !string.IsNullOrWhiteSpace(p.Asset.SerialNumber) && p.Asset.SerialNumber.Equals(candidate.SerialNumber, StringComparison.OrdinalIgnoreCase) && p.Asset.AssetTag != candidate.AssetTag) == true;
    }

