    private string newAdditionalConfig = "";
    private DateTime? newPurchaseDate = null;
    private string newStatus = "Available";
    private string newAssignmentType = "Individual";
    private int? newAssignedEmployeeID = null;
    private string newAssignedTeamName = string.Empty;
    private string newResponsiblePerson = string.Empty;
    private string newNotes = "";

    private readonly List<string> assetTypeOptions = new()
    {
        "Laptop","Macbook","Macmini", "Monitor", "Keyboard", "Mouse", "Dongle", "Mobile", "USB Cable", "USB Hub", "Webcam", "SSD", "UPS", "Laptop Stand", "Accessories", "Desktop", "Other"
    };

    private readonly List<string> ramOptions = new() { "4GB", "8GB", "16GB", "32GB", "64GB", "128GB", "N/A" };
    private readonly List<string> ssdOptions = new() { "128GB", "256GB", "512GB", "1TB", "2TB", "N/A" };

    private readonly Dictionary<string, List<string>> brandOptionsByType = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Laptop"] = new() { "Lenovo ThinkPad", "Lenovo", "HP", "Dell", "Asus", "Acer", "Other" },
        ["Macbook"] = new() { "Apple" },
        ["Macmini"] = new() { "Apple" },
        ["Monitor"] = new() { "HP", "ViewSonic", "Dell", "LG", "Samsung", "Other" },
        ["Keyboard"] = new() { "A4Tech", "Logitech", "HP", "Dell", "Other" },
        ["Mouse"] = new() { "A4Tech", "Logitech", "HP", "Dell", "Other" },
        ["Dongle"] = new() { "Ugreen", "Yuanxin", "TP Link", "HAVIT", "Non Brand", "Other" },
        ["Mobile"] = new() { "Apple iPhone", "Google Pixel", "Samsung Galaxy", "Oppo", "Motorola", "Other" },
        ["USB Cable"] = new() { "Ugreen", "Yuanxin", "Non Brand", "Other" },
        ["USB Hub"] = new() { "Ugreen", "Yuanxin", "TP Link", "Other" },
        ["Webcam"] = new() { "Logitech", "HP", "A4Tech", "Other" },
        ["SSD"] = new() { "Western Digital", "Samsung", "Kingston", "Other" },
        ["UPS"] = new() { "DigitalX", "APC", "Other" },
        ["Desktop"] = new() { "Other" }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployees();
        await LoadAssetsFromFirebase();
    }

    private async Task LoadAssetsFromFirebase()
    {
        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"{FirebaseDatabaseURL}/assets.json?auth={FirebaseApiKey}");
            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var dictionary = await response.Content.ReadFromJsonAsync<Dictionary<string, Asset>>();
                if (dictionary != null)
                {
                    assets = dictionary.Values.ToList();
                    dataTableInitialized = false;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading assets: {ex.Message}");
        }
    }

    private async Task LoadEmployees()
    {
        try
        {
            var cachedEmployees = await LoadEmployeesFromLocalStorage();
            if (cachedEmployees.Any())
            {
                employees = cachedEmployees;
                return;
            }

            var request = new HttpRequestMessage(HttpMethod.Get, $"{FirebaseDatabaseURL}/employees.json?auth={FirebaseApiKey}");
            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var payload = await response.Content.ReadFromJsonAsync<JsonElement>();
                employees = ParseEmployees(payload);
                await SaveEmployeesToLocalStorage();
            }
        }
        catch
        {
            employees = new();
        }
    }

    private async Task<List<EmployeeDirectoryEntry>> LoadEmployeesFromLocalStorage()
    {
        var json = await JSRuntime.InvokeAsync<string>("localStorage.getItem", EmployeeDirectoryCacheKey);
        if (string.IsNullOrWhiteSpace(json))
        {
            return new List<EmployeeDirectoryEntry>();
        }

        try
        {
            return JsonSerializer.Deserialize<List<EmployeeDirectoryEntry>>(json, new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            }) ?? new List<EmployeeDirectoryEntry>();
        }
        catch
        {
            return new List<EmployeeDirectoryEntry>();
        }
    }

    private async Task SaveEmployeesToLocalStorage()
    {
        var json = JsonSerializer.Serialize(employees);
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", EmployeeDirectoryCacheKey, json);
    }

    private static List<EmployeeDirectoryEntry> ParseEmployees(JsonElement payload)
    {
        var parsedEmployees = new List<EmployeeDirectoryEntry>();
        var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

        if (payload.ValueKind == JsonValueKind.Object)
        {
            foreach (var property in payload.EnumerateObject())
            {
                if (property.Value.ValueKind != JsonValueKind.Object)
                {
                    continue;
                }

                var employee = property.Value.Deserialize<EmployeeDirectoryEntry>(options);
                if (employee != null)
                {
                    parsedEmployees.Add(employee);
                }
            }
        }
        else if (payload.ValueKind == JsonValueKind.Array)
        {
            foreach (var item in payload.EnumerateArray())
            {
                if (item.ValueKind != JsonValueKind.Object)
                {
                    continue;
                }

                var employee = item.Deserialize<EmployeeDirectoryEntry>(options);
                if (employee != null)
                {
                    parsedEmployees.Add(employee);
                }
            }
        }

        return parsedEmployees.OrderBy(e => e.EmployeeID).ToList();
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (isAssetListFeatureOpen && !dataTableInitialized && assets.Any())
        {
            await JSRuntime.InvokeVoidAsync("initDataTable", "assetTable");
            dataTableInitialized = true;
        }
    }

