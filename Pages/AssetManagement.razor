@page "/asset-management"
@using Web_JbcHrms.Models
@using System.Net.Http.Json
@inject IJSRuntime JSRuntime
@inject HttpClient Http
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<PageTitle>Asset Management</PageTitle>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Asset Management</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a href="asset-tagging" class="btn btn-sm btn-outline-info me-2">
            <i class="bi bi-tags"></i> Asset Tagging
        </a>
        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="OpenAddModal">
            <i class="bi bi-plus-lg"></i> Add New Asset
        </button>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="table-responsive">
            <table class="table table-striped table-hover mt-3 align-middle" id="assetTable">
                <thead class="table-light">
                    <tr>
                        <th>Asset Tag</th>
                        <th>Type</th>
                        <th>Model</th>
                        <th>Config</th>
                        <th>Serial Number</th>
                        <th>Purchase Date</th>
                        <th>Status</th>
                        <th>Assigned To</th>
                        <th>Notes</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (assets != null && assets.Any())
                    {
                        foreach (var asset in assets)
                        {
                            <tr>
                                <td><strong>@asset.AssetTag</strong></td>
                                <td>@asset.Type</td>
                                <td>@asset.Model</td>
                                <td>@asset.Config</td>
                                <td>@asset.SerialNumber</td>
                                <td>@(asset.PurchaseDate?.ToString("dd MMM yyyy") ?? "N/A")</td>
                                <td><span class="badge @(asset.Status == "Available" ? "bg-success" : "bg-secondary")">@asset.Status</span></td>
                                <td>
                                    @if (asset.AssignedEmployeeID.HasValue)
                                    {
                                        var emp = employees.FirstOrDefault(e => e.EmployeeID == asset.AssignedEmployeeID.Value);
                                        if (emp != null)
                                        {
                                            <span>@emp.EmployeeCode - @emp.EmployeeName</span>
                                        }
                                        else
                                        {
                                            <span>Emp ID: @asset.AssignedEmployeeID.Value</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">Unassigned</span>
                                    }
                                </td>
                                <td>@asset.Notes</td>
                                <td class="text-nowrap">
                                    <button class="btn btn-sm btn-outline-secondary me-1" title="Edit" @onclick="() => OpenEditModal(asset)">
                                        <i class="bi bi-pencil"></i> Edit
                                    </button>
                                    <button class="btn btn-sm btn-outline-info" title="History" @onclick="() => ShowHistory(asset)">
                                        <i class="bi bi-clock-history"></i> History
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="text-center py-4 text-muted">No assets found. Click "Add New Asset" to create one.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add/Edit Asset Modal -->
<div class="modal fade" id="addAssetModal" tabindex="-1" aria-labelledby="addAssetModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addAssetModalLabel">@(isEditing ? "Edit Asset" : "Add New Asset")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" @onclick="CloseAddModal"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="mb-3">
                        <label class="form-label">Asset Type</label>
                        <select class="form-select" @bind="newAssetType" @bind:after="GenerateAssetTag" disabled="@isEditing">
                            <option value="">-- Select Type --</option>
                            @foreach (var assetType in assetTypeOptions)
                            {
                                <option value="@assetType">@assetType</option>
                            }
                        </select>
                    </div>

                    @if (newAssetType == "Other")
                    {
                        <div class="mb-3">
                            <label class="form-label">Custom Asset Type</label>
                            <input type="text" class="form-control" @bind="customAssetType" @bind:event="oninput" @bind:after="GenerateAssetTag" placeholder="e.g. SSD Enclosure" disabled="@isEditing" />
                        </div>
                    }
                    
                    <div class="mb-3">
                        <label class="form-label">Asset Tag (Auto-generated)</label>
                        <input type="text" class="form-control bg-light" value="@newAssetTag" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Brand</label>
                        <select class="form-select" @bind="newBrand">
                            <option value="">-- Select Brand --</option>
                            @foreach (var brand in GetBrandOptions())
                            {
                                <option value="@brand">@brand</option>
                            }
                        </select>
                    </div>

                    @if (newBrand == "Other")
                    {
                        <div class="mb-3">
                            <label class="form-label">Custom Brand</label>
                            <input type="text" class="form-control" @bind="customBrand" placeholder="e.g. No Brand" />
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Model</label>
                        <input type="text" class="form-control" @bind="newModel" placeholder="e.g. M1 2020" />
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">RAM</label>
                            <select class="form-select" @bind="newRam">
                                <option value="">-- Select RAM --</option>
                                @foreach (var ram in ramOptions)
                                {
                                    <option value="@ram">@ram</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">SSD</label>
                            <select class="form-select" @bind="newSsd">
                                <option value="">-- Select SSD --</option>
                                @foreach (var ssd in ssdOptions)
                                {
                                    <option value="@ssd">@ssd</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Additional Config (Optional)</label>
                        <input type="text" class="form-control" @bind="newAdditionalConfig" placeholder="e.g. Type-C Hub, Intel i7" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Serial Number</label>
                        <input type="text" class="form-control" @bind="newSerialNumber" placeholder="e.g. C02X..." />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Purchase Date</label>
                        <input type="date" class="form-control" @bind="newPurchaseDate" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select class="form-select" @bind="newStatus">
                            <option value="Available">Available</option>
                            <option value="Assigned">Assigned</option>
                            <option value="Maintenance">Maintenance</option>
                            <option value="Retired">Retired</option>
                        </select>
                    </div>

                    @if (newStatus == "Assigned")
                    {
                        <div class="mb-3">
                            <label class="form-label">Assign to Employee</label>
                            <select class="form-select" @bind="newAssignedEmployeeID">
                                <option value="">-- Select Employee --</option>
                                @foreach (var employee in employees)
                                {
                                    <option value="@employee.EmployeeID">@employee.EmployeeCode - @employee.EmployeeName</option>
                                }
                            </select>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea class="form-control" rows="2" @bind="newNotes"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" @onclick="CloseAddModal">Cancel</button>
                <button type="button" class="btn btn-primary" @onclick="SaveAsset" disabled="@string.IsNullOrWhiteSpace(GetEffectiveAssetType())">Save Asset</button>
            </div>
        </div>
    </div>
</div>

<!-- History Modal -->
<div class="modal fade" id="historyModal" tabindex="-1" aria-labelledby="historyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="historyModalLabel">History for @(historyAsset?.AssetTag ?? "Unknown")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" @onclick="CloseHistoryModal"></button>
            </div>
            <div class="modal-body">
                @if (historyAsset != null && historyAsset.History != null && historyAsset.History.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var entry in historyAsset.History.OrderByDescending(h => h.Date))
                        {
                            <li class="list-group-item flex-column align-items-start">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1 fw-bold">@entry.Action</h6>
                                    <small class="text-muted">@entry.Date.ToString("dd MMM yyyy HH:mm")</small>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(entry.Notes))
                                {
                                    <p class="mb-1 text-muted">@entry.Notes</p>
                                }
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">No history found for this asset.</p>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" @onclick="CloseHistoryModal">Close</button>
            </div>
        </div>
    </div>
</div>

@code {
    private string FirebaseDatabaseURL => Configuration["Firebase:DatabaseURL"] ?? "";
    private string FirebaseApiKey => Configuration["Firebase:ApiKey"] ?? "";
    private List<Asset> assets = new();
    private List<EmployeeDirectoryEntry> employees = new();

    private bool isEditing = false;
    private Asset? historyAsset = null;

    // Form fields
    private string newAssetType = "";
    private string customAssetType = "";
    private string newAssetTag = "";
    private string newSerialNumber = "";
    private string newBrand = "";
    private string customBrand = "";
    private string newModel = "";
    private string newRam = "";
    private string newSsd = "";
    private string newAdditionalConfig = "";
    private DateTime? newPurchaseDate = null;
    private string newStatus = "Available";
    private int? newAssignedEmployeeID = null;
    private string newNotes = "";

    private readonly List<string> assetTypeOptions = new()
    {
        "Laptop","Macbook","Macmini", "Monitor", "Keyboard", "Mouse", "Dongle", "Mobile", "USB Cable", "USB Hub", "Webcam", "SSD", "UPS", "Laptop Stand", "Accessories", "Desktop", "Other"
    };

    private readonly List<string> ramOptions = new() { "4GB", "8GB", "16GB", "32GB", "64GB", "128GB", "N/A" };
    private readonly List<string> ssdOptions = new() { "128GB", "256GB", "512GB", "1TB", "2TB", "N/A" };

    private readonly Dictionary<string, List<string>> brandOptionsByType = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Laptop"] = new() { "Lenovo ThinkPad", "Lenovo", "HP", "Dell", "Asus", "Acer", "Other" },
        ["Macbook"] = new() { "Apple" },
        ["Macmini"] = new() { "Apple" },
        ["Monitor"] = new() { "HP", "ViewSonic", "Dell", "LG", "Samsung", "Other" },
        ["Keyboard"] = new() { "A4Tech", "Logitech", "HP", "Dell", "Other" },
        ["Mouse"] = new() { "A4Tech", "Logitech", "HP", "Dell", "Other" },
        ["Dongle"] = new() { "Ugreen", "Yuanxin", "TP Link", "HAVIT", "Non Brand", "Other" },
        ["Mobile"] = new() { "Apple iPhone", "Google Pixel", "Samsung Galaxy", "Oppo", "Motorola", "Other" },
        ["USB Cable"] = new() { "Ugreen", "Yuanxin", "Non Brand", "Other" },
        ["USB Hub"] = new() { "Ugreen", "Yuanxin", "TP Link", "Other" },
        ["Webcam"] = new() { "Logitech", "HP", "A4Tech", "Other" },
        ["SSD"] = new() { "Western Digital", "Samsung", "Kingston", "Other" },
        ["UPS"] = new() { "DigitalX", "APC", "Other" },
        ["Desktop"] = new() { "Other" }
    };

    protected override async Task OnInitializedAsync()
    {
        await InitFirebaseAppCheck();
        await LoadEmployees();
        await LoadAssetsFromFirebase();
    }

    private async Task InitFirebaseAppCheck()
    {
        var config = new
        {
            apiKey = Configuration["Firebase:ApiKey"],
            authDomain = Configuration["Firebase:AuthDomain"],
            databaseURL = Configuration["Firebase:DatabaseURL"],
            projectId = Configuration["Firebase:ProjectId"],
            storageBucket = Configuration["Firebase:StorageBucket"],
            messagingSenderId = Configuration["Firebase:MessagingSenderId"],
            appId = Configuration["Firebase:AppId"]
        };
        var recaptchaSiteKey = Configuration["Firebase:RecaptchaSiteKey"] ?? "6LfEsr4sAAAAADu4AmwWnhrcCr-jumEguSeDoJpt";
        await JSRuntime.InvokeVoidAsync("initFirebaseAppCheck", config, recaptchaSiteKey);
    }

    private async Task LoadAssetsFromFirebase()
    {
        try
        {
            string token = await JSRuntime.InvokeAsync<string>("getRecaptchaToken");
            var request = new HttpRequestMessage(HttpMethod.Get, $"{FirebaseDatabaseURL}.json?auth={FirebaseApiKey}");
            request.Headers.Add("X-Firebase-AppCheck", token);
            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var dictionary = await response.Content.ReadFromJsonAsync<Dictionary<string, Asset>>();
                if (dictionary != null)
                {
                    assets = dictionary.Values.ToList();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading assets: {ex.Message}");
        }
    }

    private async Task LoadEmployees()
    {
        try
        {
            string token = await JSRuntime.InvokeAsync<string>("getRecaptchaToken");
            var request = new HttpRequestMessage(HttpMethod.Get, $"{FirebaseDatabaseURL}/employees.json?auth={FirebaseApiKey}");
            request.Headers.Add("X-Firebase-AppCheck", token);
            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var dictionary = await response.Content.ReadFromJsonAsync<Dictionary<string, EmployeeDirectoryEntry>>();
                employees = dictionary?.Values.OrderBy(e => e.EmployeeID).ToList() ?? new();
            }
        }
        catch
        {
            employees = new();
        }
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && assets.Any())
        {
            await JSRuntime.InvokeVoidAsync("initDataTable", "assetTable");
        }
    }

    private async Task OpenAddModal()
    {
        isEditing = false;
        ResetForm();
        await JSRuntime.InvokeVoidAsync("showModal", "addAssetModal");
    }

    private async Task OpenEditModal(Asset asset)
    {
        isEditing = true;
        var mappedType = MapTypeToOption(asset.Type);
        if (assetTypeOptions.Contains(mappedType))
        {
            newAssetType = mappedType;
            customAssetType = "";
        }
        else
        {
            newAssetType = "Other";
            customAssetType = asset.Type;
        }

        newAssetTag = asset.AssetTag;
        newSerialNumber = asset.SerialNumber ?? "";
        newBrand = "";
        customBrand = "";
        newModel = asset.Model ?? "";
        ParseConfigForEdit(asset.Config);
        newPurchaseDate = asset.PurchaseDate;
        newStatus = asset.Status ?? "Available";
        newAssignedEmployeeID = asset.AssignedEmployeeID;
        newNotes = asset.Notes ?? "";

        await JSRuntime.InvokeVoidAsync("showModal", "addAssetModal");
    }

    private async Task CloseAddModal()
    {
        await JSRuntime.InvokeVoidAsync("hideModal", "addAssetModal");
        ResetForm();
    }

    private async Task ShowHistory(Asset asset)
    {
        historyAsset = asset;
        await JSRuntime.InvokeVoidAsync("showModal", "historyModal");
    }

    private async Task CloseHistoryModal()
    {
        await JSRuntime.InvokeVoidAsync("hideModal", "historyModal");
        historyAsset = null;
    }

    private void GenerateAssetTag()
    {
        var effectiveType = GetEffectiveAssetType();
        if (string.IsNullOrWhiteSpace(effectiveType))
        {
            newAssetTag = "";
            return;
        }

        // e.g., JBC-Laptop-01
        // Find how many of this type exist
        string typePrefix = effectiveType.Replace(" ", ""); // remove spaces, e.g. MacMini
        var effectiveTypeKey = GetTypeKey(effectiveType);
        int count = assets.Count(a => GetTypeKey(a.Type) == effectiveTypeKey);
        
        newAssetTag = $"JBC-{typePrefix}-{(count + 1):D2}";
    }

    private async Task SaveAsset()
    {
        var effectiveType = GetEffectiveAssetType();
        if (string.IsNullOrWhiteSpace(effectiveType)) return;

        if (!isEditing && string.IsNullOrEmpty(newAssetTag))
        {
            GenerateAssetTag();
        }

        var asset = isEditing 
            ? assets.FirstOrDefault(a => a.AssetTag == newAssetTag) 
            : new Asset { AssetTag = newAssetTag, Type = effectiveType };

        if (asset == null) return;

        // Keep track of changes for History
        string historyAction = "";
        int? newAssignee = newStatus == "Assigned" ? newAssignedEmployeeID : null;

        string GetEmployeeName(int id)
        {
            var emp = employees.FirstOrDefault(e => e.EmployeeID == id);
            return emp != null ? $"{emp.EmployeeCode} - {emp.EmployeeName}" : $"Emp ID: {id}";
        }

        if (!isEditing)
        {
            if (newAssignee.HasValue)
            {
                historyAction = $"Assigned to {GetEmployeeName(newAssignee.Value)}";
            }
        }
        else
        {
            if (asset.AssignedEmployeeID != newAssignee)
            {
                if (newAssignee.HasValue)
                {
                    historyAction = $"Assigned to {GetEmployeeName(newAssignee.Value)}";
                }
                else if (asset.AssignedEmployeeID.HasValue)
                {
                    historyAction = $"Unassigned from {GetEmployeeName(asset.AssignedEmployeeID.Value)}";
                }
            }
        }

        // Add history entry if there was a meaningful update or creation
        if (!string.IsNullOrEmpty(historyAction))
        {
            if (asset.History == null) asset.History = new List<AssetHistory>();
            asset.History.Add(new AssetHistory
            {
                Action = historyAction,
                Notes = newNotes
            });
        }

        asset.Type = effectiveType;
        asset.SerialNumber = newSerialNumber;
        asset.Model = BuildModelValue();
        asset.Config = BuildConfigValue();
        asset.PurchaseDate = newPurchaseDate;
        asset.Status = newStatus;
        asset.Notes = newNotes;
        asset.AssignedEmployeeID = newStatus == "Assigned" ? newAssignedEmployeeID : null;

        try
        {
            string token = await JSRuntime.InvokeAsync<string>("getRecaptchaToken");
            var request = new HttpRequestMessage(HttpMethod.Put, $"{FirebaseDatabaseURL}/{asset.AssetTag}.json?auth={FirebaseApiKey}");
            request.Headers.Add("X-Firebase-AppCheck", token);
            request.Content = JsonContent.Create(asset);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                if (!isEditing)
                {
                    assets.Add(asset);
                }
                
                // Refresh DataTable
                await JSRuntime.InvokeVoidAsync("initDataTable", "assetTable");

                await JSRuntime.InvokeVoidAsync("hideModal", "addAssetModal");
                ResetForm();
            }
            else
            {
                Console.WriteLine($"Error saving asset: {response.ReasonPhrase}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception saving asset: {ex.Message}");
        }
    }

    private void ResetForm()
    {
        isEditing = false;
        newAssetType = "";
        customAssetType = "";
        newAssetTag = "";
        newSerialNumber = "";
        newBrand = "";
        customBrand = "";
        newModel = "";
        newRam = "";
        newSsd = "";
        newAdditionalConfig = "";
        newPurchaseDate = null;
        newStatus = "Available";
        newAssignedEmployeeID = null;
        newNotes = "";
    }

    private string GetEffectiveAssetType()
    {
        if (newAssetType == "Other")
        {
            return customAssetType.Trim();
        }

        return newAssetType.Trim();
    }

    private List<string> GetBrandOptions()
    {
        var effectiveType = GetEffectiveAssetType();
        if (string.IsNullOrWhiteSpace(effectiveType))
        {
            return new List<string> { "Other" };
        }

        var brandTypeKey = MapTypeToOption(effectiveType);

        if (brandOptionsByType.TryGetValue(brandTypeKey, out var brands))
        {
            return brands;
        }

        return new List<string> { "Other" };
    }

    private string BuildModelValue()
    {
        var brand = newBrand == "Other" ? customBrand.Trim() : newBrand.Trim();
        if (string.IsNullOrWhiteSpace(brand))
        {
            return newModel.Trim();
        }

        if (string.IsNullOrWhiteSpace(newModel))
        {
            return brand;
        }

        return $"{brand} {newModel.Trim()}";
    }

    private string BuildConfigValue()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(newRam))
        {
            parts.Add($"RAM: {newRam}");
        }

        if (!string.IsNullOrWhiteSpace(newSsd))
        {
            parts.Add($"SSD: {newSsd}");
        }

        if (!string.IsNullOrWhiteSpace(newAdditionalConfig))
        {
            parts.Add(newAdditionalConfig.Trim());
        }

        return string.Join(" | ", parts);
    }

    private void ParseConfigForEdit(string? config)
    {
        newRam = "";
        newSsd = "";
        newAdditionalConfig = "";

        if (string.IsNullOrWhiteSpace(config))
        {
            return;
        }

        var parts = config.Split('|', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
        var remaining = new List<string>();

        foreach (var part in parts)
        {
            if (part.StartsWith("RAM:", StringComparison.OrdinalIgnoreCase))
            {
                newRam = part.Substring(4).Trim();
                continue;
            }

            if (part.StartsWith("SSD:", StringComparison.OrdinalIgnoreCase))
            {
                newSsd = part.Substring(4).Trim();
                continue;
            }

            remaining.Add(part);
        }

        if (remaining.Any())
        {
            newAdditionalConfig = string.Join(" | ", remaining);
        }
        else if (string.IsNullOrWhiteSpace(newRam) && string.IsNullOrWhiteSpace(newSsd))
        {
            newAdditionalConfig = config;
        }
    }

    private string MapTypeToOption(string? assetType)
    {
        return GetTypeKey(assetType) switch
        {
            "macbook" => "Macbook",
            "macmini" => "Macmini",
            "monitor" => "Monitor",
            "laptop" => "Laptop",
            "desktop" => "Desktop",
            "keyboard" => "Keyboard",
            "mouse" => "Mouse",
            "dongle" => "Dongle",
            "mobile" => "Mobile",
            "usbcable" => "USB Cable",
            "usbhub" => "USB Hub",
            "webcam" => "Webcam",
            "ssd" => "SSD",
            "ups" => "UPS",
            "laptopstand" => "Laptop Stand",
            "accessories" => "Accessories",
            _ => assetType?.Trim() ?? ""
        };
    }

    private string GetTypeKey(string? assetType)
    {
        if (string.IsNullOrWhiteSpace(assetType))
        {
            return string.Empty;
        }

        var cleaned = assetType.Trim().ToLowerInvariant().Replace("-", " ");
        cleaned = string.Join(" ", cleaned.Split(' ', StringSplitOptions.RemoveEmptyEntries));

        return cleaned switch
        {
            "mac book" => "macbook",
            "mac mini" => "macmini",
            "monior" => "monitor",
            "usb cable" => "usbcable",
            "usb hub" => "usbhub",
            "laptop stand" => "laptopstand",
            _ => cleaned.Replace(" ", "")
        };
    }
}
