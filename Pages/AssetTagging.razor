@page "/asset-tagging"
@using Web_JbcHrms.Models
@using System.Net.Http.Json
@inject IJSRuntime JSRuntime
@inject HttpClient Http
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<PageTitle>Asset Tagging</PageTitle>

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Asset Tagging</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <button class="btn btn-sm btn-success" @onclick="PrintSelectedTags" disabled="@(!selectedAssets.Any())">
            <i class="bi bi-printer"></i> Print Selected (@selectedAssets.Count)
        </button>
    </div>
</div>

<div class="mb-3">
    <button class="btn btn-outline-primary" @onclick="ToggleAllCheckboxes">
        @(allChecked ? "Uncheck All" : "Check All")
    </button>
</div>

<div class="row">
    <div class="col-12">
        <div class="table-responsive">
            <table class="table table-striped table-hover mt-3 align-middle" id="assetTaggingTable">
                <thead class="table-light">
                    <tr>
                        <th class="checkbox-cell">
                            <input hidden type="checkbox" @bind="allChecked" />
                        </th>
                        <th>Asset Tag</th>
                        <th>Type</th>
                        <th>Model</th>
                        <th>Serial Number</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (assets != null && assets.Any())
                    {
                        foreach (var asset in assets)
                        {
                            <tr>
                                <td class="checkbox-cell">
                                    <input type="checkbox" class="custom-checkbox" checked="@GetAssetSelection(asset)" @onchange="e => HandleCheckboxChange(asset, e)" />
                                </td>
                                <td><strong>@asset.AssetTag</strong></td>
                                <td>@asset.Type</td>
                                <td>@asset.Model</td>
                                <td>@asset.SerialNumber</td>
                                <td><span class="badge @(asset.Status == "Available" ? "bg-success" : "bg-secondary")">@asset.Status</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">No assets found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Print Preview Modal -->
<div class="modal fade" id="printPreviewModal" tabindex="-1" aria-labelledby="printPreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="printPreviewModalLabel">Print Preview - Asset Tags</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="max-height: 70vh; overflow-y: auto;">
                <div id="assetTagsPrint">
                    <style>
                        .asset-tags-page {
                            display: block;
                            padding: 20px;
                            background: white;
                            text-align: left;
                        }
                        .asset-tag-card {
                            display: inline-block;
                            vertical-align: top;
                            width: 30%; /* 3 columns based on container width */
                            margin: 1.5%;
                            border: 2px dashed #000;
                            padding: 15px;
                            text-align: center;
                            position: relative;
                            background-color: #fff;
                            page-break-inside: avoid;
                            box-sizing: border-box;
                        }
                        .asset-tag-card::before {
                            content: '✁E;
                            position: absolute;
                            top: -12px;
                            left: -10px;
                            font-size: 16px;
                            color: #888;
                        }
                        .asset-tag-logo {
                            max-width: 100px;
                            margin-bottom: 10px;
                        }
                        .asset-tag-title {
                            font-size: 14px;
                            font-weight: bold;
                            margin-bottom: 5px;
                        }
                        .asset-tag-info {
                            font-size: 12px;
                            text-align: left;
                            margin-top: 10px;
                        }
                        .asset-tag-info div {
                            margin-bottom: 2px;
                        }
                        .asset-tag-number {
                            font-size: 18px;
                            font-weight: bold;
                            margin-top: 10px;
                            border: 1px solid #000;
                            padding: 5px;
                        }
                    </style>
                    <div class="report-a4-container">
                        <div class="report-a4-page asset-tags-page">
                            @if (printAssets.Any())
                            {
                                @foreach (var asset in printAssets)
                                {
                                    <div class="asset-tag-card">
                                        <img src="images/logo.svg" alt="JB Connect Ltd." class="asset-tag-logo" />
                                        <div class="asset-tag-title">JB Connect Ltd. Property</div>
                                        <div class="asset-tag-info">
                                            <div><strong>Type:</strong> @asset.Type</div>
                                            <div><strong>Model:</strong> @(string.IsNullOrEmpty(asset.Model) ? "N/A" : asset.Model)</div>
                                            <div><strong>S/N:</strong> @(string.IsNullOrEmpty(asset.SerialNumber) ? "N/A" : asset.SerialNumber)</div>
                                        </div>
                                        <div class="asset-tag-number">@asset.AssetTag</div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center w-100">No assets selected.</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" @onclick="ConfirmPrint">
                    <i class="bi bi-printer"></i> Print Tags
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private string FirebaseDatabaseURL => Configuration["Firebase:DatabaseURL"] ?? "";
    private string FirebaseApiKey => Configuration["Firebase:ApiKey"] ?? "";
    private List<Asset> assets = new();
    private HashSet<Asset> selectedAssets = new HashSet<Asset>();
    private List<Asset> printAssets = new();
    private bool allChecked = false;
    private bool dataTableInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        await InitFirebaseAppCheck();
        await LoadAssetsFromFirebase();
    }

    private async Task InitFirebaseAppCheck()
    {
        var config = new
        {
            apiKey = Configuration["Firebase:ApiKey"],
            authDomain = Configuration["Firebase:AuthDomain"],
            databaseURL = Configuration["Firebase:DatabaseURL"],
            projectId = Configuration["Firebase:ProjectId"],
            storageBucket = Configuration["Firebase:StorageBucket"],
            messagingSenderId = Configuration["Firebase:MessagingSenderId"],
            appId = Configuration["Firebase:AppId"]
        };
        var recaptchaSiteKey = Configuration["Firebase:RecaptchaSiteKey"] ?? "6LfEsr4sAAAAADu4AmwWnhrcCr-jumEguSeDoJpt";
        await JSRuntime.InvokeVoidAsync("initFirebaseAppCheck", config, recaptchaSiteKey);
    }

    private async Task LoadAssetsFromFirebase()
    {
        try
        {
            string token = await JSRuntime.InvokeAsync<string>("getRecaptchaToken");
            var request = new HttpRequestMessage(HttpMethod.Get, $"{FirebaseDatabaseURL}.json?auth={FirebaseApiKey}");
            request.Headers.Add("X-Firebase-AppCheck", token);
            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var dictionary = await response.Content.ReadFromJsonAsync<Dictionary<string, Asset>>();
                if (dictionary != null)
                {
                    assets = dictionary.Values.ToList();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading assets: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!dataTableInitialized && assets != null && assets.Any())
        {
            await JSRuntime.InvokeVoidAsync("initDataTable", "assetTaggingTable");
            dataTableInitialized = true;
        }
    }

    private bool GetAssetSelection(Asset asset)
    {
        return selectedAssets.Contains(asset);
    }

    private void SetAssetSelection(Asset asset, bool isSelected)
    {
        if (isSelected)
        {
            selectedAssets.Add(asset);
        }
        else
        {
            selectedAssets.Remove(asset);
        }
        UpdateAllCheckedState();
        StateHasChanged();
    }

    private void ToggleAllCheckboxes()
    {
        if (assets == null) return;

        if (allChecked)
        {
            selectedAssets.Clear();
            allChecked = false;
        }
        else
        {
            selectedAssets.Clear();
            foreach (var asset in assets)
            {
                selectedAssets.Add(asset);
            }
            allChecked = true;
        }
        StateHasChanged();
    }

    private void UpdateAllCheckedState()
    {
        if (assets == null || assets.Count == 0)
        {
            allChecked = false;
            return;
        }
        allChecked = assets.All(asset => selectedAssets.Contains(asset));
    }

    private void HandleCheckboxChange(Asset asset, ChangeEventArgs e)
    {
        bool isChecked = e.Value is bool value && value;
        SetAssetSelection(asset, isChecked);
    }

    private async Task PrintSelectedTags()
    {
        if (assets == null || !selectedAssets.Any())
        {
            return;
        }

        printAssets = assets
            .Where(asset => selectedAssets.Contains(asset))
            .OrderBy(asset => asset.AssetTag)
            .ToList();

        await InvokeAsync(StateHasChanged);
        await Task.Delay(50);
        await JSRuntime.InvokeVoidAsync("showModal", "printPreviewModal");
    }

    private async Task ConfirmPrint()
    {
        await JSRuntime.InvokeVoidAsync("hideModal", "printPreviewModal");
        await Task.Delay(100);
        await JSRuntime.InvokeVoidAsync("printReport", "assetTagsPrint", "Asset Tags");
    }
}
