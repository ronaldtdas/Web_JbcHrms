@page "/employees"

@using System.Net.Http.Json
@using System.Text.Json
@using Web_JbcHrms.Models
@inject IJSRuntime JSRuntime
@inject HttpClient Http
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<h3>Employees</h3>

<div class="mb-3" hidden>
    <button class="btn btn-primary" @onclick="LoadEmployeesFromFirebase" disabled="@isLoading">
        @(isLoading ? "Loading..." : "Refresh from Firebase")
    </button>
    <button class="btn btn-outline-danger ms-2" @onclick="SeedEmployeesToFirebase" disabled="@(isLoading || isSeeding)">
        @(isSeeding ? "Seeding..." : "Admin: Seed/Update Firebase")
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(seedMessage))
{
    <div class="alert @(seedSuccess ? "alert-success" : "alert-warning")">@seedMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (employees.Any())
{
    <div class="table-responsive">
        <table id="employeeDirectoryTable" class="table table-striped table-bordered table-hover w-100">
            <thead class="table-dark">
                <tr>
                    <th>Employee Id</th>
                    <th>Employee Name</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in employees)
                {
                    <tr>
                        <td>@emp.EmployeeCode</td>
                        <td>@emp.EmployeeName</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (!isLoading)
{
    <div class="alert alert-info">No employees found in Firebase.</div>
}

@code {
    private FirebaseConfigOptions FirebaseConfig => Configuration.GetSection("FirebaseConfig").Get<FirebaseConfigOptions>() ?? new();
    private string FirebaseDatabaseURL => FirebaseConfig.DatabaseURL;
    private string FirebaseApiKey => FirebaseConfig.ApiKey;
    private const string EmployeeDirectoryCacheKey = "employeeDirectoryEntries";

    private List<EmployeeDirectoryEntry> employees = new();
    private bool isLoading;
    private bool isSeeding;
    private bool dataTableInitialized;
    private string? errorMessage;
    private string? seedMessage;
    private bool seedSuccess;

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployeesFromFirebase();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!dataTableInitialized && employees.Any())
        {
            await JSRuntime.InvokeVoidAsync("initDataTable", "employeeDirectoryTable");
            dataTableInitialized = true;
        }
    }

    private async Task LoadEmployeesFromFirebase()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, $"{FirebaseDatabaseURL}/employees.json?auth={FirebaseApiKey}");

            var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                employees = new();
                errorMessage = $"Unable to load employees from Firebase ({(int)response.StatusCode} {response.ReasonPhrase}).";
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<JsonElement>();
            employees = ParseEmployees(payload);
            dataTableInitialized = false;
            await SaveEmployeesToLocalStorage();
        }
        catch (Exception ex)
        {
            employees = new();
            errorMessage = $"Unable to load employees: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SeedEmployeesToFirebase()
    {
        isSeeding = true;
        seedMessage = null;

        try
        {
            var seedData = await Http.GetFromJsonAsync<Dictionary<string, EmployeeDirectoryEntry>>("data/firebase_employees.json");
            if (seedData == null || seedData.Count == 0)
            {
                seedSuccess = false;
                seedMessage = "Seed file is empty or missing.";
                return;
            }

            var request = new HttpRequestMessage(HttpMethod.Put, $"{FirebaseDatabaseURL}/employees.json?auth={FirebaseApiKey}");
            request.Content = JsonContent.Create(seedData);

            var response = await Http.SendAsync(request);
            if (!response.IsSuccessStatusCode)
            {
                seedSuccess = false;
                seedMessage = $"Failed to seed Firebase ({(int)response.StatusCode} {response.ReasonPhrase}).";
                return;
            }

            await LoadEmployeesFromFirebase();
            seedSuccess = true;
            seedMessage = $"Firebase employees updated successfully ({seedData.Count} records).";
        }
        catch (Exception ex)
        {
            seedSuccess = false;
            seedMessage = $"Seed failed: {ex.Message}";
        }
        finally
        {
            isSeeding = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SaveEmployeesToLocalStorage()
    {
        var json = JsonSerializer.Serialize(employees);
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", EmployeeDirectoryCacheKey, json);
    }

    private static List<EmployeeDirectoryEntry> ParseEmployees(JsonElement payload)
    {
        var parsedEmployees = new List<EmployeeDirectoryEntry>();
        var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };

        if (payload.ValueKind == JsonValueKind.Object)
        {
            foreach (var property in payload.EnumerateObject())
            {
                if (property.Value.ValueKind != JsonValueKind.Object)
                {
                    continue;
                }

                var employee = property.Value.Deserialize<EmployeeDirectoryEntry>(options);
                if (employee != null)
                {
                    parsedEmployees.Add(employee);
                }
            }
        }
        else if (payload.ValueKind == JsonValueKind.Array)
        {
            foreach (var item in payload.EnumerateArray())
            {
                if (item.ValueKind != JsonValueKind.Object)
                {
                    continue;
                }

                var employee = item.Deserialize<EmployeeDirectoryEntry>(options);
                if (employee != null)
                {
                    parsedEmployees.Add(employee);
                }
            }
        }

        return parsedEmployees.OrderBy(e => e.EmployeeID).ToList();
    }
}
