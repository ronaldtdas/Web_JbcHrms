@page "/login"
@layout LoginLayout
@attribute [AllowAnonymous]
@inject CustomAuthStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<div class="login-container">
    <div class="login-card shadow-lg">
        <div class="card-header text-center bg-primary text-white p-4">
            <h3>JBC HRMS</h3>
            <p class="mb-0">Please sign in to continue</p>
        </div>
        <div class="card-body p-4">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @errorMessage
                </div>
            }
            <EditForm Model="@loginRequest" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <InputText id="username" class="form-control" @bind-Value="loginRequest.Username" placeholder="Enter username" />
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <InputText id="password" type="password" class="form-control" @bind-Value="loginRequest.Password" placeholder="Enter password" />
                </div>
                <button type="submit" class="btn btn-primary w-100" disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span> Signing in...</span>
                    }
                    else
                    {
                        <span>Sign In</span>
                    }
                </button>
            </EditForm>
        </div>
        <div class="card-footer text-center text-muted p-3">
            <small>Mock login: use any username/password</small>
        </div>
    </div>
</div>

<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        background-color: #f8f9fa;
    }
    .login-card {
        width: 100%;
        max-width: 400px;
        background: white;
        border-radius: 10px;
        overflow: hidden;
    }
    .card-header h3 {
        margin: 0;
        font-weight: 700;
        letter-spacing: 1px;
    }
</style>

@code {
    private LoginRequest loginRequest = new();
    private string errorMessage = string.Empty;
    private bool isProcessing = false;

    private async Task HandleLogin()
    {
        isProcessing = true;
        errorMessage = string.Empty;

        // Mock authentication logic
        await Task.Delay(1000); // Simulate network delay

        if (!string.IsNullOrEmpty(loginRequest.Username) && !string.IsNullOrEmpty(loginRequest.Password))
        {
            var userSession = new UserSession
            {
                UserName = loginRequest.Username,
                Token = Guid.NewGuid().ToString(),
                Role = "Admin"
            };

            await AuthStateProvider.UpdateAuthenticationState(userSession);
            NavigationManager.NavigateTo("employees");
        }
        else
        {
            errorMessage = "Invalid username or password.";
        }

        isProcessing = false;
    }
}
