@page "/salary-certificate"

@using Web_JbcHrms.Models
@using CsvHelper
@using System.Globalization
@using System.IO
@using System.Linq
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@inject IJSRuntime JSRuntime

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="text-center mb-5">
                <h2 class="mb-4">Salary Certificate</h2>

                @if (!string.IsNullOrEmpty(lastFileName))
                {
                    <div class="alert alert-info text-start">
                        <strong>Last imported file:</strong> @lastFileName
                        @if (lastUpdated.HasValue)
                        {
                            <div class="text-muted mt-1">Last updated: @lastUpdated.Value.ToString("dd MMMM, yyyy hh:mm tt")</div>
                        }
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(dataUploadMessage))
                {
                    <div class="alert @(dataUploadSuccess ? "alert-success" : "alert-danger") text-start">@dataUploadMessage</div>
                }

                <div class="mb-4 text-start">
                    <InputFile id="@FileInputId" accept=".csv" style="position: absolute; left: -9999px;" OnChange="HandleFileChange" />
                    <label for="@FileInputId" class="btn btn-primary mb-0 me-2">Upload CSV</label>
                    <button @onclick="SyncData" class="btn btn-secondary me-2">Sync Data</button>
                    <button @onclick="ClearData" class="btn btn-outline-danger">Clear Data</button>
                </div>

                
                <div class="search-container mb-4">
                    <div class="input-group input-group-lg">
                        <input type="text" class="form-control" placeholder="Search employees by name..." @bind="searchQuery" @bind:event="oninput" @onkeydown="HandleSearchKeyDown" />
                        <button class="btn btn-primary" type="button" @onclick="PerformSearch">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>

                
                @if (searchResults != null && searchResults.Any())
                {
                    <div class="search-results">
                        <h5 class="text-muted mb-3">Search Results (@searchResults.Count)</h5>
                        @foreach (var employee in searchResults)
                        {
                            <div class="card mb-2">
                                <div class="card-body d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="card-title mb-1">@employee.Salutation @employee.FirstName @employee.LastName</h6>
                                        <p class="card-text text-muted mb-0">@employee.Designation</p>
                                    </div>
                                    <div>
                                        <button class="btn btn-sm btn-info me-2" @onclick="() => ViewEmployee(employee)">
                                            <i class="bi bi-eye"></i> View
                                        </button>
                                        <button class="btn btn-sm btn-secondary" @onclick="() => PrintCertificate(employee)">
                                            <i class="bi bi-printer"></i> Print
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (!string.IsNullOrEmpty(searchQuery) && searchResults != null && !searchResults.Any())
                {
                    <div class="text-center text-muted">
                        <p>No employees found matching "@searchQuery"</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

 
@if (showViewModal && selectedEmployee != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title">View Employee Details</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseViewModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-2">
                        <div class="col-md-6"><strong>Employee ID:</strong> @selectedEmployee.EmployeeID</div>
                        <div class="col-md-6"><strong>Salutation:</strong> @selectedEmployee.Salutation</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-6"><strong>First Name:</strong> @selectedEmployee.FirstName</div>
                        <div class="col-md-6"><strong>Last Name:</strong> @selectedEmployee.LastName</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-6"><strong>Designation:</strong> @selectedEmployee.Designation</div>
                        <div class="col-md-6"><strong>Joining Date:</strong> @selectedEmployee.JoiningDate.ToString("dd MMMM, yyyy")</div>
                    </div>
                    <hr />
                    <h6 class="text-primary">Salary Details</h6>
                    <div class="row mb-2">
                        <div class="col-md-6"><strong>Gross:</strong> @selectedEmployee.Gross.ToString("N0") ৳</div>
                        <div class="col-md-6"><strong>Basic Salary:</strong> @selectedEmployee.BasicSalary.ToString("N0") ৳</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-6"><strong>House Allowance:</strong> @selectedEmployee.HouseAllowance.ToString("N0") ৳</div>
                        <div class="col-md-6"><strong>Medical Allowance:</strong> @selectedEmployee.MedicalAllowance.ToString("N0") ৳</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-6"><strong>Travel Allowance:</strong> @selectedEmployee.TravelAllowance.ToString("N0") ৳</div>
                        <div class="col-md-6"><strong>Transport Allowance:</strong> @selectedEmployee.TransportAllowance.ToString("N0") ৳</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-6"><strong>Performance Allowance:</strong> @selectedEmployee.PerformanceAllowance.ToString("N0") ৳</div>
                        <div class="col-md-6"><strong>Miscellaneous:</strong> @selectedEmployee.Miscellaneous.ToString("N0") ৳</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-6"><strong>Monthly Tax Deduction:</strong> @selectedEmployee.MonthlyTaxDeduction.ToString("N0") ৳</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseViewModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="printPreviewModal" tabindex="-1" aria-labelledby="printPreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="printPreviewModalLabel">Print Preview - Salary Certificate</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="max-height: 80vh; overflow-y: auto;">
                <div id="salaryCertificatePrint">
                    <ReportLayout>
                        <section class="report-subject text-center" style="margin-top: 20px; font-size: 20px;">
                            <p class=""><strong>SALARY CERTIFICATE</strong></p>
                        </section>
                        <section class="report-recipient text-end">
                            <p>Issued Date: @printGeneratedAt.ToString("dd MMMM yyyy")</p>
                        </section>

                        <section class="report-body-section">
                            <p>This is to certify that @printEmployee?.Salutation @printEmployee?.FirstName @printEmployee?.LastName 
                                is a permanent employee of <strong>JB Connect Ltd.</strong>, 
                                holding the position <strong>@printEmployee?.Designation</strong>. @if (printEmployee?.Salutation == "Mr.") { <span>He</span> } else { <span>She</span> } joined the company on <strong>@printEmployee?.JoiningDate.ToString("dd MMMM yyyy")</strong>. 
                                @if (printEmployee?.Salutation == "Mr.") { <span>His</span> } else { <span>Her</span> } current monthly gross salary amount is <strong>@printEmployee?.Gross.ToString("N0")/= BDT</strong>, 
                                with an additional monthly transport allowance of <strong>@printEmployee?.TransportAllowance.ToString("N0")/= BDT</strong>. 
                                @if (printEmployee?.Salutation == "Mr.") { <span>His</span> } else { <span>Her</span> } total monthly salary with additional Allowance (if any) is 
                                <strong>@(((printEmployee?.Gross ?? 0) + (printEmployee?.TransportAllowance ?? 0) + (printEmployee?.PerformanceAllowance ?? 0)).ToString("N0"))/= BDT</strong>. 
                                The current monthly salary details are as follows:</p>
                            
                            <table class="table table-bordered table-sm report-table" style="font-size: 0.82rem; line-height: 1.2;">
                                <thead>
                                    <tr>
                                        <th>Particulars</th>
                                        <th>Amount (BDT)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Basic Salary</td>
                                        <td class="text-end">@printEmployee?.BasicSalary.ToString("N2")</td>
                                    </tr>
                                    <tr>
                                        <td>House Allowance</td>
                                        <td class="text-end">@printEmployee?.HouseAllowance.ToString("N2")</td>
                                    </tr>
                                    <tr>
                                        <td>Medical Allowance</td>
                                        <td class="text-end">@printEmployee?.MedicalAllowance.ToString("N2")</td>
                                    </tr>
                                    <tr>
                                        <td>Travel Allowance</td>
                                        <td class="text-end">@printEmployee?.TravelAllowance.ToString("N2")</td>
                                    </tr>
                                    <tr>
                                        <td>Miscellaneous</td>
                                        <td class="text-end">@printEmployee?.Miscellaneous.ToString("N2")</td>
                                    </tr>
                                    <tr>
                                        <td><strong>Total Monthly Gross Salary</strong></td>
                                        <td class="text-end"><strong>@printEmployee?.Gross.ToString("N2")</strong></td>
                                    </tr>
                                    <tr>
                                        <td>Transport Allowance (Monthly)</td>
                                        <td class="text-end">@printEmployee?.TransportAllowance.ToString("N2")</td>
                                    </tr>
                                    @if (printEmployee?.PerformanceAllowance > 0)
                                    {
                                        <tr>
                                            <td>Additional [Performance/Team Lead/CR] Allowance (Monthly)</td>
                                            <td class="text-end">@printEmployee?.PerformanceAllowance.ToString("N2")</td>
                                        </tr>
                                    }
                                    <tr>
                                        <td><strong>Total Monthly Salary</strong></td>
                                        <td class="text-end"><strong>@(((printEmployee?.Gross ?? 0) + (printEmployee?.TransportAllowance ?? 0) + (printEmployee?.PerformanceAllowance ?? 0)).ToString("00.00"))</strong></td>
                                    </tr>
                                    <tr>
                                        <td>Monthly Tax Deduction</td>
                                        <td class="text-end">@printEmployee?.MonthlyTaxDeduction.ToString("N2")</td>
                                    </tr>
                                    <tr>
                                        <td><strong>Total Monthly Salary in BDT (After Tax Deduction)</strong></td>
                                        <td class="text-end"><strong>@(((printEmployee?.Gross ?? 0) + (printEmployee?.TransportAllowance ?? 0) + (printEmployee?.PerformanceAllowance ?? 0) - (printEmployee?.MonthlyTaxDeduction ?? 0)).ToString("N2"))</strong></td>
                                    </tr>
                                </tbody>
                            </table>

                            <p>Salary amount in words: <strong>@NumberToWords(((printEmployee?.Gross ?? 0) + (printEmployee?.TransportAllowance ?? 0) + (printEmployee?.PerformanceAllowance ?? 0) - (printEmployee?.MonthlyTaxDeduction ?? 0))) Taka Only (Monthly).</strong></p>
                            <p>In addition to the monthly salary, @printEmployee?.Salutation @printEmployee?.FirstName @printEmployee?.LastName is entitled to receive two festival bonuses (Eid bonuses) and yearly performance bonus as per company policy.</p>
                        </section>

                        <section class="report-closing">
                            <p>Sincerely,</p>
                        </section>

                        <section class="report-signature">
                            <p class="mb-0">------------------------------</p>
                            <p class="mb-0">Tanzima Chowdhury</p>
                            <p class="mb-0">Manager, HR & Admin</p>
                            <p class="mb-0">JB Connect Ltd.</p>
                            <p class="mb-0">Contact: +8801601699646</p>
                            <p class="mb-0">Email: hr@jbc-bd.com</p>
                        </section>
                    </ReportLayout>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" @onclick="ConfirmPrint">
                    <i class="bi bi-printer"></i> Print
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private const string FileInputId = "salaryCertificateFileInput";
    private const long MaxFileSize = 10 * 1024 * 1024;
    private List<Employee>? employees;
    private string searchQuery = "";
    private List<Employee>? searchResults;
    private bool showViewModal = false;
    private Employee? selectedEmployee;
    private Employee? printEmployee;
    private DateTime printGeneratedAt = DateTime.Now;
    private string? lastFileName;
    private DateTime? lastUpdated;
    private string? dataUploadMessage;
    private bool dataUploadSuccess;

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployeesFromStorage();
    }

    private async Task LoadEmployeesFromStorage()
    {
        var json = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "employees");
        if (!string.IsNullOrEmpty(json))
        {
            employees = JsonSerializer.Deserialize<List<Employee>>(json);
        }

        lastFileName = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "lastFileName");
        var lastUpdatedValue = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "lastUpdated");
        if (!string.IsNullOrEmpty(lastUpdatedValue) && DateTime.TryParse(lastUpdatedValue, CultureInfo.InvariantCulture, DateTimeStyles.RoundtripKind, out var parsedLastUpdated))
        {
            lastUpdated = parsedLastUpdated.ToLocalTime();
        }
        else
        {
            lastUpdated = null;
        }
    }

    private async Task HandleFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null)
        {
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(MaxFileSize);
            using var reader = new StreamReader(stream);
            var content = await reader.ReadToEndAsync();
            await ReceiveFileContent(content, file.Name);
        }
        catch (Exception ex)
        {
            dataUploadSuccess = false;
            dataUploadMessage = $"Unable to read CSV: {ex.Message}";
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SaveToLocalStorage()
    {
        if (employees == null)
        {
            return;
        }

        var json = JsonSerializer.Serialize(employees);
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "employees", json);
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "lastFileName", lastFileName ?? "");
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "lastUpdated", lastUpdated?.ToString("o") ?? "");
    }

    private async Task SyncData()
    {
        await LoadEmployeesFromStorage();
        searchResults = new List<Employee>();
        dataUploadSuccess = true;
        dataUploadMessage = "Employee data synced from browser storage.";
    }

    private async Task ClearData()
    {
        employees = null;
        searchResults = new List<Employee>();
        searchQuery = string.Empty;
        lastFileName = null;
        lastUpdated = null;

        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "employees");
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "lastFileName");
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "lastUpdated");

        dataUploadSuccess = true;
        dataUploadMessage = "Employee data cleared from browser storage.";
    }

    private async Task ReceiveFileContent(string content, string fileName)
    {
        try
        {
            using var csv = new CsvReader(new StringReader(content), CultureInfo.InvariantCulture);
            employees = csv.GetRecords<Employee>().ToList();

            lastFileName = fileName;
            lastUpdated = DateTime.Now;
            await SaveToLocalStorage();

            searchResults = new List<Employee>();
            dataUploadSuccess = true;
            dataUploadMessage = "Employee CSV uploaded successfully.";
        }
        catch (Exception ex)
        {
            dataUploadSuccess = false;
            dataUploadMessage = $"Unable to process CSV: {ex.Message}";
        }

        await InvokeAsync(StateHasChanged);
    }

    private void PerformSearch()
    {
        if (string.IsNullOrWhiteSpace(searchQuery) || employees == null)
        {
            searchResults = new List<Employee>();
            return;
        }

        var query = searchQuery.ToLowerInvariant();
        searchResults = employees
            .Where(e =>
                e.FirstName.ToLowerInvariant().Contains(query) ||
                e.LastName.ToLowerInvariant().Contains(query) ||
                $"{e.FirstName} {e.LastName}".ToLowerInvariant().Contains(query) ||
                $"{e.Salutation} {e.FirstName} {e.LastName}".ToLowerInvariant().Contains(query))
            .Take(5)
            .ToList();
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            PerformSearch();
        }
    }

    private void ViewEmployee(Employee employee)
    {
        selectedEmployee = employee;
        showViewModal = true;
    }

    private void CloseViewModal()
    {
        showViewModal = false;
        selectedEmployee = null;
    }

    private async Task PrintCertificate(Employee employee)
    {
        printEmployee = employee;
        printGeneratedAt = DateTime.Now;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(50);
        await JSRuntime.InvokeVoidAsync("showModal", "printPreviewModal");
    }

    private async Task ConfirmPrint()
    {
        await JSRuntime.InvokeVoidAsync("hideModal", "printPreviewModal");
        await Task.Delay(100);
        await JSRuntime.InvokeVoidAsync("printReport", "salaryCertificatePrint", "Salary Certificate");
    }

    private string NumberToWords(decimal number)
    {
        if (number == 0) return "Zero";

        string[] units = { "", "One", "Two", "Three", "Four", "Five", "Six", "Seven", "Eight", "Nine" };
        string[] teens = { "Ten", "Eleven", "Twelve", "Thirteen", "Fourteen", "Fifteen", "Sixteen", "Seventeen", "Eighteen", "Nineteen" };
        string[] tens = { "", "", "Twenty", "Thirty", "Forty", "Fifty", "Sixty", "Seventy", "Eighty", "Ninety" };

        string ConvertToWords(long n)
        {
            if (n < 10) return units[n];
            if (n < 20) return teens[n - 10];
            if (n < 100) return tens[n / 10] + (n % 10 != 0 ? " " + units[n % 10] : "");
            if (n < 1000) return units[n / 100] + " Hundred" + (n % 100 != 0 ? " " + ConvertToWords(n % 100) : "");
            if (n < 100000) return ConvertToWords(n / 1000) + " Thousand" + (n % 1000 != 0 ? " " + ConvertToWords(n % 1000) : "");
            if (n < 10000000) return ConvertToWords(n / 100000) + " Lakh" + (n % 100000 != 0 ? " " + ConvertToWords(n % 100000) : "");
            return ConvertToWords(n / 10000000) + " Crore" + (n % 10000000 != 0 ? " " + ConvertToWords(n % 10000000) : "");
        }

        long wholeNumber = (long)number;
        return ConvertToWords(wholeNumber);
    }
}